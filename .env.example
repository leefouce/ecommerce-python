# FastAPI app settings
APP_TOKEN_SECRET=replace-with-a-long-random-secret
APP_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Docker Compose PostgreSQL settings
POSTGRES_DB=ecommerce
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=change-me

# Direct app database URL. In Docker Compose, compose.yaml builds this from the POSTGRES_* values.
APP_DATABASE_URL=postgresql+psycopg://ecommerce:change-me@localhost:5432/ecommerce
